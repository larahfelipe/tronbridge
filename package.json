{
  "name": "tronbridge",
  "version": "0.0.0",
  "main": "Server.js",
  "repository": "https://github.com/larafe1/tronbridge.git",
  "author": "larafe1",
  "license": "MIT",
  "scripts": {
    "start": "node -r ts-node/register -r tsconfig-paths/register dist/Server.js",
    "dev": "tsnd --respawn --transpile-only --exit-child -r tsconfig-paths/register src/Server.ts",
    "build": "tsc --project tsconfig.json&&tscpaths -p tsconfig.json -s src -o dist",
    "lint": "eslint src --ext ts --max-warnings=0",
    "lint:fix": "eslint src --ext ts --max-warnings=0 --fix",
    "prettier": "prettier --check \"src/**/*.ts\"",
    "prettier:fix": "prettier --check \"src/**/*.ts\" --write",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^8.2.1",
    "dotenv": "^16.0.3",
    "fastify": "^4.17.0",
    "tronweb": "^5.1.0",
    "tsconfig-paths": "^4.2.0",
    "tscpaths": "^0.0.9",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^20.1.0",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "@typescript-eslint/parser": "^5.59.2",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import-helpers": "^1.3.1",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4"
  }
}
